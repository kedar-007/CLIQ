{
  "name": "@comms/desktop",
  "version": "1.0.0",
  "description": "DSV-CLIQ Desktop App",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "start": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "electron-store": "^8.2.0",
    "electron-log": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dsv.cliq",
    "productName": "DSV-CLIQ",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**", "src/**"],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage"
    },
    "protocols": {
      "name": "DSV-CLIQ",
      "schemes": ["dsvcliq"]
    }
  }
}
