# ─── DATABASE ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/comms_platform
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BROKERS=localhost:9092

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_64_chars_long_for_security
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_64_chars_long_for_security
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── S3 / MINIO ─────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=comms-platform
S3_REGION=us-east-1
CDN_BASE_URL=http://localhost:9000/comms-platform

# ─── LIVEKIT ────────────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── TWILIO ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ─── AI SERVICES ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ─── OAUTH ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# ─── EMAIL ──────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@commsplatform.local
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── STRIPE ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── WEB PUSH (VAPID) ───────────────────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@commsplatform.local

# ─── GIPHY ──────────────────────────────────────────────────────
GIPHY_API_KEY=your_giphy_api_key

# ─── SERVICES PORTS ─────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
CHAT_SERVICE_PORT=3002
CALL_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
FILE_SERVICE_PORT=3005
SEARCH_SERVICE_PORT=3006
CALENDAR_SERVICE_PORT=3007
TASK_SERVICE_PORT=3008
BOT_SERVICE_PORT=3009
INTEGRATION_SERVICE_PORT=3010
AI_SERVICE_PORT=3011
ANALYTICS_SERVICE_PORT=3012
BILLING_SERVICE_PORT=3013

# ─── SERVICE URLS (internal) ────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
CHAT_SERVICE_URL=http://localhost:3002
CALL_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
FILE_SERVICE_URL=http://localhost:3005
SEARCH_SERVICE_URL=http://localhost:3006
CALENDAR_SERVICE_URL=http://localhost:3007
TASK_SERVICE_URL=http://localhost:3008
BOT_SERVICE_URL=http://localhost:3009
INTEGRATION_SERVICE_URL=http://localhost:3010
AI_SERVICE_URL=http://localhost:3011
ANALYTICS_SERVICE_URL=http://localhost:3012
BILLING_SERVICE_URL=http://localhost:3013

# ─── APP ────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret_at_least_32_chars
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3002
NEXT_PUBLIC_LIVEKIT_URL=wss://localhost:7880

# ─── CLAMAV ─────────────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ─── FEATURE FLAGS ──────────────────────────────────────────────
ENABLE_AI_FEATURES=true
ENABLE_PSTN_CALLING=false
ENABLE_OCR=true
ENABLE_VIRUS_SCAN=true
